{
  "uid": "ledger",
  "title": "Ledger",
  "description": "The three things worth watching: how much money is moving, how fast requests return, and whether the outbox relay is keeping up.",
  "tags": ["ledger"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Money movements / s",
      "description": "Successful writes: transfers, multi-leg postings, and hold captures, over REST and gRPC.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ledger_http_requests_total{route=~\"POST /v1/(transfers|postings|holds/\\\\{id\\\\}/capture)\",status=~\"2..\"}[1m]))",
          "legendFormat": "REST"
        },
        {
          "refId": "B",
          "expr": "sum(rate(ledger_grpc_requests_total{method=~\"/ledger.v1.LedgerService/(Transfer|CreatePosting|Capture)\",code=\"OK\"}[1m]))",
          "legendFormat": "gRPC"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request latency p99",
      "description": "99th percentile over a 5m window, per transport.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ledger_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "REST p99"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ledger_grpc_request_duration_seconds_bucket[5m])))",
          "legendFormat": "gRPC p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Outbox backlog",
      "description": "Rows awaiting publication. A healthy relay keeps this near zero; a broker outage makes it climb — and nothing is lost, delivery resumes where it left off.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "ledger_outbox_unpublished", "legendFormat": "unpublished rows" },
        {
          "refId": "B",
          "expr": "rate(ledger_outbox_published_total[1m])",
          "legendFormat": "published / s"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox lag",
      "description": "Age of the oldest unpublished event — the time an event has been waiting to reach the broker.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "ledger_outbox_lag_seconds", "legendFormat": "oldest unpublished" }
      ]
    }
  ]
}
